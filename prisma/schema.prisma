generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id                Int        @id @default(autoincrement())
  name              String     @db.VarChar(100)
  email             String     @unique @db.VarChar(191)
  phoneNumber       String     @map("phone_number") @db.VarChar(20)
  password          String     @db.VarChar(255)
  role              Role       @default(ADMIN_USER)
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  lastLoginAt        DateTime? @map("last_login_at")

  // ── Hierarchy ──
  createdById       Int?       @map("created_by_id")
  createdBy         User?      @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  createdUsers      User[]     @relation("UserCreatedBy")

  superAdminId      Int?       @map("super_admin_id")
  superAdmin        User?      @relation("SuperAdminOwnership", fields: [superAdminId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  adminUsers        User[]     @relation("SuperAdminOwnership")

  // ── Location scope ──
  primaryLocationId Int?       @map("primary_location_id")
  primaryLocation   Location?  @relation("PrimaryLocation", fields: [primaryLocationId], references: [id], onDelete: SetNull)
  locations         UserLocation[]         @relation("UserLocations")
  assignedLocations UserLocation[]         @relation("LocationAssignedBy")

  // ── Permissions (as the Admin User being granted permissions) ──
  permissions         AdminUserPermission[] @relation("AdminUserPermissions")
  permissionsAssigned AdminUserPermission[] @relation("PermissionAssignedBy")

  // ── Created records (audit) ──
  locationsCreated  Location[] @relation("LocationCreatedBy")

  @@map("users")
}

// ─── Locations ────────────────────────────────────────────────────────────

model Location {
  id          Int            @id @default(autoincrement())
  name        String         @db.VarChar(100)
  code        String         @unique @db.VarChar(30)
  address     String?        @db.Text
  city        String?        @db.VarChar(100)
  state       String?        @db.VarChar(100)
  status      LocationStatus @default(ACTIVE)
  createdById Int?           @map("created_by_id")
  createdBy   User?          @relation("LocationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  users           UserLocation[]
  primaryUsers    User[]            @relation("PrimaryLocation")
  vehicleRecords  VehicleRecord[]
  healthInsurance HealthInsurance[]
  fireInsurance   FireInsurance[]
  labourInsurance LabourInsurance[]
  permissions     AdminUserPermission[]

  @@map("locations")
}

model UserLocation {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation("UserLocations", fields: [userId], references: [id], onDelete: Cascade)
  locationId   Int      @map("location_id")
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  assignedById Int?     @map("assigned_by_id")
  assignedBy   User?    @relation("LocationAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, locationId])
  @@map("user_locations")
}

// ─── Admin User Permissions ─────────────────────────────────────────────────

model AdminUserPermission {
  id           Int       @id @default(autoincrement())
  adminUserId  Int       @map("admin_user_id")
  adminUser    User      @relation("AdminUserPermissions", fields: [adminUserId], references: [id], onDelete: Cascade)
  locationId   Int?      @map("location_id")
  location     Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  moduleName   String    @db.VarChar(50) @map("module_name")
  canView      Boolean   @default(false) @map("can_view")
  canCreate    Boolean   @default(false) @map("can_create")
  canUpdate    Boolean   @default(false) @map("can_update")
  canDelete    Boolean   @default(false) @map("can_delete")
  canExport    Boolean   @default(false) @map("can_export")
  assignedById Int?      @map("assigned_by_id")
  assignedBy   User?     @relation("PermissionAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([adminUserId, moduleName])
  @@map("admin_user_permissions")
}

// ─── Lead Sources ────────────────────────────────────────────────────────────

model LeadSource {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lead_sources")
}

// ─── Insurance Companies ─────────────────────────────────────────────────────

model InsuranceCompany {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(150)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("insurance_companies")
}

// ─── Vehicle Categories ──────────────────────────────────────────────────────

model VehicleCategory {
  id        Int               @id @default(autoincrement())
  name      String            @unique @db.VarChar(50)
  parentId  Int?              @map("parent_id")
  parent    VehicleCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children  VehicleCategory[] @relation("CategoryChildren")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@map("vehicle_categories")
}

// ─── Vehicle Records ─────────────────────────────────────────────────────────

model VehicleRecord {
  id                Int      @id @default(autoincrement())
  locationId        Int?     @map("location_id")
  location          Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  vehicleNumber     String   @db.VarChar(50) @map("vehicle_number")
  ownerName         String   @db.VarChar(100) @map("owner_name")
  cellNumber        String   @db.VarChar(20) @map("cell_number")
  cellNumberAlt     String?  @db.VarChar(20) @map("cell_number_alt")
  category          String   @db.VarChar(50)
  policyExpiryDate  DateTime @db.Date @map("policy_expiry_date")
  insuranceCompany  String   @db.VarChar(150) @map("insurance_company")
  rcDocument        String?  @db.VarChar(500) @map("rc_document")
  insuranceDocument String?  @db.VarChar(500) @map("insurance_document")
  aadhaarDocument   String?  @db.VarChar(500) @map("aadhaar_document")
  panDocument       String?  @db.VarChar(500) @map("pan_document")
  photo             String?  @db.VarChar(500)
  odDocument        String?  @db.VarChar(500) @map("od_document")
  tpDocument        String?  @db.VarChar(500) @map("tp_document")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  renewals          VehicleRenewal[]
  notificationLogs  NotificationLog[]

  @@map("vehicle_records")
}

// ─── Renewal Tracking ────────────────────────────────────────────────────────

model VehicleRenewal {
  id              Int           @id @default(autoincrement())
  vehicleRecordId Int           @map("vehicle_record_id")
  vehicleRecord   VehicleRecord @relation(fields: [vehicleRecordId], references: [id], onDelete: Cascade)
  status          RenewalStatus @default(CONTACTED)
  notes           String?       @db.Text
  renewedDate     DateTime?     @map("renewed_date")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("vehicle_renewals")
}

// ─── Notification Settings ───────────────────────────────────────────────────

model NotificationSettings {
  id                   Int      @id @default(autoincrement())
  firstAlertDays       Int      @default(30) @map("first_alert_days")
  secondAlertDays      Int      @default(15) @map("second_alert_days")
  finalAlertDays       Int      @default(7)  @map("final_alert_days")
  enableWhatsApp       Boolean  @default(true)  @map("enable_whatsapp")
  enableEmail          Boolean  @default(false) @map("enable_email")
  enableSms            Boolean  @default(false) @map("enable_sms")
  schedulerHour        Int      @default(8)    @map("scheduler_hour")
  language             String   @default("english") @db.VarChar(10)  @map("language")
  contactName          String?  @db.VarChar(100) @map("contact_name")
  contactPhone         String?  @db.VarChar(20)  @map("contact_phone")
  contactAddress       String?  @db.VarChar(300) @map("contact_address")
  whatsappApiKey       String?  @db.VarChar(500) @map("whatsapp_api_key")
  whatsappApiUrl       String?  @db.VarChar(500) @map("whatsapp_api_url")
  whatsappMessageId    String   @default("23258")            @db.VarChar(50)  @map("whatsapp_message_id")
  whatsappPhoneNumberId String  @default("1092173950656058") @db.VarChar(100) @map("whatsapp_phone_number_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt      @map("updated_at")

  @@map("notification_settings")
}

// ─── Notification Logs ───────────────────────────────────────────────────────

model NotificationLog {
  id                 Int              @id @default(autoincrement())
  vehicleRecordId    Int?             @map("vehicle_record_id")
  vehicleRecord      VehicleRecord?   @relation(fields: [vehicleRecordId], references: [id], onDelete: SetNull)
  healthInsuranceId  Int?             @map("health_insurance_id")
  healthInsurance    HealthInsurance? @relation(fields: [healthInsuranceId], references: [id], onDelete: SetNull)
  mobileNumber       String           @db.VarChar(20)  @map("mobile_number")
  notificationType   NotificationType @map("notification_type")
  message            String           @db.Text
  status             NotifStatus      @default(PENDING)
  response           String?          @db.Text
  sentAt             DateTime         @default(now())  @map("sent_at")

  @@map("notification_logs")
}

// ─── Health Insurance ────────────────────────────────────────────────────────

model HealthInsurance {
  id                    Int                          @id @default(autoincrement())
  locationId            Int?                         @map("location_id")
  location              Location?                    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  policyNumber          String                       @unique @db.VarChar(100) @map("policy_number")
  insuranceCompanyName  String                       @db.VarChar(150)         @map("insurance_company_name")
  policyHolderName      String                       @db.VarChar(100)         @map("policy_holder_name")
  mobileNumber          String                       @db.VarChar(20)          @map("mobile_number")
  email                 String?                      @db.VarChar(191)
  dateOfBirth           DateTime?                    @db.Date                 @map("date_of_birth")
  gender                String?                      @db.VarChar(10)
  address               String?                      @db.Text
  policyType            HealthPolicyType             @map("policy_type")
  policyStartDate       DateTime                     @db.Date                 @map("policy_start_date")
  policyEndDate         DateTime                     @db.Date                 @map("policy_end_date")
  renewalDate           DateTime                     @db.Date                 @map("renewal_date")
  policyStatus          HealthPolicyStatus           @default(ACTIVE)         @map("policy_status")
  sumInsured            Decimal                      @db.Decimal(12, 2)       @map("sum_insured")
  premiumAmount         Decimal                      @db.Decimal(10, 2)       @map("premium_amount")
  paymentMode           HealthPaymentMode?           @map("payment_mode")
  customerType          HealthCustomerType           @default(NEW)            @map("customer_type")
  leadSource            String?                      @db.VarChar(100)         @map("lead_source")
  renewalReminderStatus String?                      @db.VarChar(50)          @map("renewal_reminder_status")
  remarks               String?                      @db.Text
  nomineeName           String?                      @db.VarChar(100)         @map("nominee_name")
  nomineeRelationship   String?                      @db.VarChar(50)          @map("nominee_relationship")
  nomineeMobileNumber   String?                      @db.VarChar(20)          @map("nominee_mobile_number")
  policyDocument        String?                      @db.VarChar(500)         @map("policy_document")
  idProof               String?                      @db.VarChar(500)         @map("id_proof")
  medicalDocument       String?                      @db.VarChar(500)         @map("medical_document")
  createdAt             DateTime                     @default(now())          @map("created_at")
  updatedAt             DateTime                     @updatedAt               @map("updated_at")
  familyMembers         HealthInsuranceFamilyMember[]
  notificationLogs      NotificationLog[]
  renewals              HealthInsuranceRenewal[]

  @@map("health_insurance")
}

model HealthInsuranceFamilyMember {
  id                 Int             @id @default(autoincrement())
  healthInsuranceId  Int             @map("health_insurance_id")
  healthInsurance    HealthInsurance @relation(fields: [healthInsuranceId], references: [id], onDelete: Cascade)
  memberName         String          @db.VarChar(100) @map("member_name")
  relationship       String          @db.VarChar(50)
  dateOfBirth        DateTime?       @db.Date         @map("date_of_birth")
  gender             String?         @db.VarChar(10)
  medicalHistory     String?         @db.Text         @map("medical_history")
  preExistingDisease String?         @db.VarChar(255) @map("pre_existing_disease")
  createdAt          DateTime        @default(now())  @map("created_at")
  updatedAt          DateTime        @updatedAt       @map("updated_at")

  @@map("health_insurance_family_members")
}

// ─── Health Renewal Tracking ─────────────────────────────────────────────────

model HealthInsuranceRenewal {
  id                Int             @id @default(autoincrement())
  healthInsuranceId Int             @map("health_insurance_id")
  healthInsurance   HealthInsurance @relation(fields: [healthInsuranceId], references: [id], onDelete: Cascade)
  status            RenewalStatus   @default(CONTACTED)
  notes             String?         @db.Text
  renewedDate       DateTime?       @map("renewed_date")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt      @map("updated_at")

  @@map("health_insurance_renewals")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  MASTER_ADMIN
  SUPER_ADMIN
  ADMIN_USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum LocationStatus {
  ACTIVE
  INACTIVE
}

enum RenewalStatus {
  CONTACTED
  DOCS_COLLECTED
  PROCESSING
  PAYMENT_PENDING
  RENEWED
  CANCELLED
}

enum NotificationType {
  EXPIRY_30
  EXPIRY_15
  EXPIRY_7
  EXPIRY_TODAY
  EXPIRED
  RENEWED
  MANUAL
}

enum NotifStatus {
  SENT
  FAILED
  PENDING
}

enum HealthPolicyType {
  INDIVIDUAL
  FAMILY_FLOATER
  SENIOR_CITIZEN
  GROUP_INSURANCE
  CRITICAL_ILLNESS
}

enum HealthPolicyStatus {
  ACTIVE
  EXPIRED
  PENDING_RENEWAL
  CANCELLED
}

enum HealthPaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}

enum HealthCustomerType {
  NEW
  RENEWAL
}

// ─── Fire Insurance ──────────────────────────────────────────────────────────

model FireInsurance {
  id                   Int                @id @default(autoincrement())
  locationId           Int?               @map("location_id")
  location             Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  policyNumber         String             @unique @db.VarChar(100) @map("policy_number")
  insuranceCompanyName String             @db.VarChar(150)         @map("insurance_company_name")
  insuredName          String             @db.VarChar(150)         @map("insured_name")
  mobileNumber         String             @db.VarChar(20)          @map("mobile_number")
  email                String?            @db.VarChar(191)
  address              String?            @db.Text
  gstNumber            String?            @db.VarChar(50)          @map("gst_number")
  businessType         String?            @db.VarChar(200)         @map("business_type")
  policyStartDate      DateTime           @db.Date                 @map("policy_start_date")
  policyEndDate        DateTime           @db.Date                 @map("policy_end_date")
  renewalDate          DateTime           @db.Date                 @map("renewal_date")
  policyStatus         FirePolicyStatus   @default(ACTIVE)         @map("policy_status")
  sumInsured           Decimal            @db.Decimal(14,2)        @map("sum_insured")
  netPremium           Decimal            @db.Decimal(10,2)        @map("net_premium")
  cgst                 Decimal?           @db.Decimal(10,2)
  sgst                 Decimal?           @db.Decimal(10,2)
  stampDuty            Decimal?           @db.Decimal(10,2)        @map("stamp_duty")
  totalPremium         Decimal            @db.Decimal(10,2)        @map("total_premium")
  receiptNumber        String?            @db.VarChar(100)         @map("receipt_number")
  receiptDate          DateTime?          @db.Date                 @map("receipt_date")
  agentName            String?            @db.VarChar(100)         @map("agent_name")
  agentCode            String?            @db.VarChar(50)          @map("agent_code")
  financierName        String?            @db.VarChar(200)         @map("financier_name")
  customerType         FireCustomerType   @default(NEW)            @map("customer_type")
  leadSource           String?            @db.VarChar(100)         @map("lead_source")
  remarks              String?            @db.Text
  policyDocument       String?            @db.VarChar(500)         @map("policy_document")
  createdAt            DateTime           @default(now())          @map("created_at")
  updatedAt            DateTime           @updatedAt               @map("updated_at")
  renewals             FireInsuranceRenewal[]

  @@map("fire_insurance")
}

model FireInsuranceRenewal {
  id              Int           @id @default(autoincrement())
  fireInsuranceId Int           @map("fire_insurance_id")
  fireInsurance   FireInsurance @relation(fields: [fireInsuranceId], references: [id], onDelete: Cascade)
  status          RenewalStatus @default(CONTACTED)
  notes           String?       @db.Text
  renewedDate     DateTime?     @map("renewed_date")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt      @map("updated_at")

  @@map("fire_insurance_renewals")
}

// ─── Labour Insurance ────────────────────────────────────────────────────────

model LabourInsurance {
  id                   Int                  @id @default(autoincrement())
  locationId           Int?                 @map("location_id")
  location             Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  policyNumber         String               @unique @db.VarChar(100) @map("policy_number")
  insuranceCompanyName String               @db.VarChar(150)         @map("insurance_company_name")
  insuredName          String               @db.VarChar(150)         @map("insured_name")
  mobileNumber         String               @db.VarChar(20)          @map("mobile_number")
  email                String?              @db.VarChar(191)
  address              String?              @db.Text
  businessDescription  String?              @db.Text                 @map("business_description")
  gstNumber            String?              @db.VarChar(50)          @map("gst_number")
  intermediaryCode     String?              @db.VarChar(50)          @map("intermediary_code")
  intermediaryName     String?              @db.VarChar(150)         @map("intermediary_name")
  policyStartDate      DateTime             @db.Date                 @map("policy_start_date")
  policyEndDate        DateTime             @db.Date                 @map("policy_end_date")
  renewalDate          DateTime             @db.Date                 @map("renewal_date")
  policyStatus         LabourPolicyStatus   @default(ACTIVE)         @map("policy_status")
  numberOfEmployees    Int?                 @map("number_of_employees")
  wagesPerEmployee     Decimal?             @db.Decimal(12,2)        @map("wages_per_employee")
  totalDeclaredWages   Decimal?             @db.Decimal(14,2)        @map("total_declared_wages")
  premium              Decimal              @db.Decimal(10,2)
  cgst                 Decimal?             @db.Decimal(10,2)
  sgst                 Decimal?             @db.Decimal(10,2)
  totalPremium         Decimal              @db.Decimal(10,2)        @map("total_premium")
  receiptNumber        String?              @db.VarChar(100)         @map("receipt_number")
  receiptDate          DateTime?            @db.Date                 @map("receipt_date")
  labourPolicyType     LabourPolicyType     @default(UNNAMED)        @map("labour_policy_type")
  customerType         LabourCustomerType   @default(NEW)            @map("customer_type")
  leadSource           String?              @db.VarChar(100)         @map("lead_source")
  remarks              String?              @db.Text
  policyDocument       String?              @db.VarChar(500)         @map("policy_document")
  createdAt            DateTime             @default(now())          @map("created_at")
  updatedAt            DateTime             @updatedAt               @map("updated_at")
  renewals             LabourInsuranceRenewal[]

  @@map("labour_insurance")
}

model LabourInsuranceRenewal {
  id                Int             @id @default(autoincrement())
  labourInsuranceId Int             @map("labour_insurance_id")
  labourInsurance   LabourInsurance @relation(fields: [labourInsuranceId], references: [id], onDelete: Cascade)
  status            RenewalStatus   @default(CONTACTED)
  notes             String?         @db.Text
  renewedDate       DateTime?       @map("renewed_date")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt      @map("updated_at")

  @@map("labour_insurance_renewals")
}

enum FirePolicyStatus {
  ACTIVE
  EXPIRED
  PENDING_RENEWAL
  CANCELLED
}

enum FireCustomerType {
  NEW
  RENEWAL
}

enum LabourPolicyStatus {
  ACTIVE
  EXPIRED
  PENDING_RENEWAL
  CANCELLED
}

enum LabourPolicyType {
  UNNAMED
  NAMED
}

enum LabourCustomerType {
  NEW
  RENEWAL
}
